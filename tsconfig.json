{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "paths": {
      "#plugin/*": ["./.opencode/plugins/open-artisan/*"],
      "#core/*": ["./packages/core/*"],
      "#bridge/*": ["./packages/bridge/*"],
      "#claude-code/*": ["./packages/claude-code/*"]
    }
  },
  "include": [
    ".opencode/plugins/open-artisan/**/*.ts",
    "packages/core/**/*.ts",
    "packages/bridge/**/*.ts",
    "packages/claude-code/**/*.ts",
    "tests/**/*.ts"
  ]
}
