    "hermes_name": "oa_mark_satisfied",
    "bridge_name": "mark_satisfied",
    "description": "Submit self-review criteria assessment for the current artifact.",
    "schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "criteria_met": {
          "type": "array",
