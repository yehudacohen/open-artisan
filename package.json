{
  "name": "open-artisan",
  "version": "0.1.0",
  "type": "module",
  "imports": {
    "#plugin/*": "./.opencode/plugins/open-artisan/*",
    "#core/*": "./packages/core/*",
    "#bridge/*": "./packages/bridge/*",
    "#claude-code/*": "./packages/claude-code/*"
  },
  "scripts": {
    "dogfood:discord": "bun run tools/discord-dogfood-harness.ts",
    "generate:hermes-tools": "bun run tools/generate-hermes-tool-contracts.ts",
    "check:generated": "bun run tools/check-generated-artifacts.ts",
    "verify:all": "bun run generate:hermes-tools && bun run check:generated && bun run typecheck && git diff --check && bun run test",
    "test": "bun run test:root && bun run test:packages && bun run test:pglite && bun run test:hermes",
    "test:root": "bun run tools/run-test-shard.ts root",
    "test:packages": "bun run test:bridge && bun run test:core",
    "test:bridge": "bun run tools/run-test-shard.ts bridge",
    "test:core": "bun run tools/run-test-shard.ts core",
    "test:pglite": "bun run tools/run-test-shard.ts pglite",
    "test:hermes": "uv run --project packages/adapter-hermes --with pytest pytest packages/adapter-hermes/tests",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/emscripten": "^1.41.5",
    "gel": "^2.2.0",
    "mysql2": "^3.22.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.4.4",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "json-rpc-2.0": "^1.7.1",
    "kysely": "^0.28.16",
    "kysely-pglite-dialect": "^1.3.1",
    "pino": "^10.3.1",
    "zod": "^4.4.1"
  }
}
