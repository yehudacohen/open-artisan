              "met": {
                "type": "boolean"
              },
              "evidence": {
                "type": "string"
              },
              "severity": {
                "type": "string",
                "enum": [
                  "blocking",
                  "suggestion",
                  "design-invariant"
                ]
              },
              "score": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "number"
                  }
                ]
              }
            },
            "required": [
