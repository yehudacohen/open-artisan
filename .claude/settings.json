{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun run packages/claude-code/bin/artisan-hook.ts pre-tool-use"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run packages/claude-code/bin/artisan-hook.ts stop"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bun run packages/claude-code/bin/artisan-hook.ts session-start"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run packages/claude-code/bin/artisan-hook.ts pre-compact"
          }
        ]
      }
    ]
  }
}
